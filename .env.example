# ====================================================================
# Morning Anxiety Guide - Environment Variables
# ====================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to `.env`:
#      cp .env.example .env
# 2. Fill in the values below. DO NOT commit .env to git.
# 3. When you finish, save and close the file.
#
# NEVER paste tokens in chat. Edit this file directly.
# ====================================================================


# --------------------------------------------------------------------
# GitHub Personal Access Token (Fine-grained)
# --------------------------------------------------------------------
# Used to push code to GitHub.
#
# Create one at: https://github.com/settings/personal-access-tokens
# - Token name: morninganxietyguide-nas (or anything you like)
# - Resource owner: YOUR_GITHUB_USERNAME
# - Repository access: Only select repositories → choose your repo
# - Permissions: Contents = Read and write
# - Expiration: 90 days (recommended)
#
# Format: github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
# Paste it below (no quotes needed):
# --------------------------------------------------------------------

GITHUB_TOKEN=


# --------------------------------------------------------------------
# Vercel Token (Optional - for CLI deploys)
# --------------------------------------------------------------------
# Used to deploy to Vercel via CLI. Not needed if you use
# `vercel login` browser flow instead.
#
# Create one at: https://vercel.com/account/tokens
# - Name: morninganxietyguide-nas
# - Scope: Full access (or restricted to your project)
# - Expiration: 90 days
#
# Format: xxxxxxxxxxxxxxxxxxxxxxxx
# Paste it below (no quotes needed):
# --------------------------------------------------------------------

VERCEL_TOKEN=


# --------------------------------------------------------------------
# Vercel Project Settings (for automated deploys)
# --------------------------------------------------------------------
# After your first deploy, Vercel will give you a project ID.
# You can find it in: Vercel Dashboard → Project → Settings → General
# --------------------------------------------------------------------

VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
